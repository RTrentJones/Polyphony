# Polyphony Environment Configuration
# Copy this file to .env and update with your actual values
#
# WARNING: Fields marked as REQUIRED must be set or the application will not start
# NEVER commit .env file to git!

# Application
DEBUG=false
ENVIRONMENT=development   # development | production

# Database — prefer a full DSN (e.g. a Neon URL); the POSTGRES_* components
# are the docker-compose fallback. One of DATABASE_URL / POSTGRES_PASSWORD is REQUIRED.
# DATABASE_URL=postgresql://user:pass@host/db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=polyphony
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-min-8-chars

# Vector search rides the SAME Postgres via pgvector — no separate store.

# LLM backend (see app/llm/providers.py). The provider's own key env var must
# be set: gemini→GEMINI_API_KEY, groq→GROQ_API_KEY, xai→XAI_API_KEY,
# openai→OPENAI_API_KEY, cerebras→CEREBRAS_API_KEY,
# openrouter→OPENROUTER_API_KEY, mistral→MISTRAL_API_KEY.
# Gemini (AI Studio free tier) is the default; groq/cerebras/openrouter/mistral
# also have free tiers — used mainly as the EVAL JUDGE (EVAL_JUDGE_PROVIDER).
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# LLM_MODEL=            # override the provider default (gemini-2.5-flash)
# LLM_MODEL_FAST=       # override the fast model (gemini-2.5-flash-lite)
# LLM_MAX_RPM=          # override free-tier pacing

# Auth (REQUIRED, >= 32 chars)
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars

# First-boot admin (created only when the users table is empty)
# ADMIN_EMAIL=you@example.com
# ADMIN_PASSWORD=

# Per-user rolling-24h LLM token budget (0 disables)
USER_DAILY_TOKEN_LIMIT=200000

# CORS (comma-separated). Same-origin static frontend needs nothing extra.
ALLOWED_ORIGINS=http://localhost:3000
