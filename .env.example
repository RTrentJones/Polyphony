# Polyphony Environment Configuration
# Copy this file to .env and update with your actual values

# Application
APP_NAME=Polyphony
APP_VERSION=1.0.0
DEBUG=false

# Database - PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=polyphony
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-change-this

# Vector Database - Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Cache/Queue - Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# LLM APIs
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Authentication/Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=your-secret-key-min-32-characters-long-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Service URLs
API_GATEWAY_URL=http://api-gateway:8000
ORCHESTRATOR_URL=http://orchestrator:8001
CHARACTER_AGENT_URLS=http://hermione:8002,http://harry:8003,http://ron:8004

# File Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=.txt,.docx,.pdf,.html,.htm

# Monitoring
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3001

# Service-specific (set per service)
SERVICE_NAME=
SERVICE_PORT=8000
CHARACTER_NAME=
CHARACTER_ID=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# RAG Settings
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5

# Scene Generation
DEFAULT_TARGET_WORD_COUNT=500
MAX_SCENE_WORD_COUNT=3000
MIN_SCENE_WORD_COUNT=100
MAX_SCENE_BEATS=10

# Cache
CACHE_TTL_SECONDS=3600
CACHE_DIALOGUE=true
